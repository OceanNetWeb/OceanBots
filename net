import asyncio
import discord
from discord.ext import commands

# 1. Настройка прав (Intents)
intents = discord.Intents.default()
intents.message_content = True
intents.members = True

# 2. Функция-шаблон для создания ботов
def create_farm_bot(name, activity_text):
    bot = commands.Bot(command_prefix="!", intents=intents)

    @bot.event
    async def on_ready():
        await bot.change_presence(activity=discord.Game(name=activity_text))
        print(f"[{name}] Бот {bot.user.name} успешно запущен и онлайн!")

    @bot.command()
    async def status(ctx):
        """Команда для проверки работы конкретного бота"""
        await ctx.send(f"🤖 Модуль **{name}** активен. Задержка: {round(bot.latency * 1000)}мс")

    return bot

# 3. Инициализируем каждого бота со своим кастомным статусом
