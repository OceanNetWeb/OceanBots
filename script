-- === ДИНАМИЧЕСКИЙ ПОДСЧЕТ LUCKY ARROWS ===
local function countLuckyArrows()
    local count = 0
    for _, item in ipairs(LocalPlayer:WaitForChild("Backpack"):GetChildren()) do
        if item.Name == EXCLUDED_ITEM then count = count + 1 end
    end
    if LocalPlayer.Character then
        for _, item in ipairs(LocalPlayer.Character:GetChildren()) do
            if item.Name == EXCLUDED_ITEM then count = count + 1 end
        end
    end
    return count
end

-- === ОТПРАВКА ВЕБХУКОВ ===
local function sendWebhook(url, statusMessage, titleField, valueField, pingUser)
    local Content = pingUser and ("<@" .. MY_DISCORD_ID .. ">") or ""
    local fields = {
        { name = 'Аккаунт', value = Username, inline = true },
        { name = 'Ферма', value = FARM_NAME, inline = true },
        { name = titleField, value = valueField, inline = false }
    }
    local Embed = {
        title = statusMessage,
        color = 32767,
        thumbnail = { url = AvatarUrl },
        fields = fields,
        timestamp = string.format('%d-%02d-%02dT%02d:%02d:%02dZ', os.date('!*t').year, os.date('!*t').month, os.date('!*t').day, os.date('!*t').hour, os.date('!*t').min, os.date('!*t').sec)
    }
    if requestFunc then
        pcall(function()
            requestFunc({
                Url = url,
                Method = 'POST',
                Headers = { ['Content-Type'] = 'application/json', ['User-Agent'] = 'Mozilla/5.0' },
                Body = HttpService:JSONEncode({ username = "Ocean.net (" .. FARM_NAME .. ")", content = Content, embeds = { Embed } })
            })
        end)
    end
end

-- === ПРОВЕРКА ЛИМИТОВ ДЛЯ ЗАВЕРШЕНИЯ ФАРМА ===
local function checkFarmLimits()
    if farmFinished then return end
    
    local luckyCount = countLuckyArrows()
    local moneyValue = 0
    pcall(function() moneyValue = LocalPlayer:WaitForChild("PlayerStats"):WaitForChild("Money").Value end)
    
    -- Условие 1: 10 стрел и >= 75,000 денег ИЛИ Условие 2: 9 стрел и >= 82,500 денег
    if (luckyCount >= 10 and moneyValue >= 75000) or (luckyCount >= 9 and moneyValue >= 82500) then
        farmFinished = true
        sendWebhook(TARGET_IMPORTANT_WEBHOOK, "Фарм успешно завершен! 🎉", "Статус", string.format("Достигнут лимит ресурсов!\nСтрелы: %d\nДеньги: %d", luckyCount, moneyValue), true)
    end
end

-- === ЛОГИКА ПОДБОРА ПРЕДМЕТОВ ===
local function onItemAdded(item)
    if item:IsA("Tool") then
        local itemName = item.Name
        if itemName == "Punch" or itemName == "Block" then return end
        if sentItems[item] then return end
        sentItems[item] = true
        
        item.Destroying:Connect(function() sentItems[item] = nil end)
        
        local isLucky = false
        if itemName:lower():match("lucky%s+arrow") or itemName == EXCLUDED_ITEM then
            isLucky = true
        end
        
        sendWebhook(TARGET_ITEM_WEBHOOK, "Получен предмет", "Имя предмета", itemName, isLucky)
        task.spawn(checkFarmLimits)
    end
end

LocalPlayer:WaitForChild("Backpack").ChildAdded:Connect(onItemAdded)

