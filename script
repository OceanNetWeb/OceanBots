            remote:FireServer(unpack({
                "EndDialogue",
                { Option = "Option1", Dialogue = "Dialogue5", NPC = "Merchant" }
            }))
        end
    end
end

LocalPlayer:WaitForChild("Backpack").ChildAdded:Connect(processItem)
