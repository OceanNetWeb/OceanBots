-- === ОТСЛЕЖИВАНИЕ ВЫЛЕТОВ И КИКОВ ===
local function cleanReason(rawText)
    if not rawText or rawText == "Label" or rawText == "" then return "Обычный кик / Разрыв соединения" end
    local clean = rawText:gsub("You have been kicked by this experience or its moderators%.%s*", "")
    clean = clean:gsub("Moderation message:%s*", "")
    clean = clean:gsub("%s*%(?Error [Cc]ode:%s*%d+%)?.*", "")
    clean = clean:gsub("%s*Error [Cc]ode:%s*%d+.*", "")
    if clean == "" or clean:match("^%s*$") or clean == "Label" then return "Обычный кик / Разрыв соединения" end
    return clean:match("^%s*(.-)%s*$")
end

