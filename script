local function initFarmDetection()
    if not requestFunc then return end
    for _, farm in ipairs(Farms) do
        local success, res = pcall(function() return requestFunc({ Url = farm.Url, Method = "GET" }) end)
        if success and res and res.Body then
            for line in res.Body:gmatch("[^\r\n]+") do
                local cleanLine = line:gsub("%s+", "")
                if cleanLine:lower() == Username:lower() then
                    TARGET_IMPORTANT_WEBHOOK = farm.ImportantWebhook
                    TARGET_ITEM_WEBHOOK = farm.ItemWebhook
                    FARM_NAME = farm.Name
                    return
                end
            end
        end
    end
end
